{
    "compilerOptions": {
        "target": "ES2020",
        "outDir": "js",
        "rootDir": "src",
        "strict": true,
        "noEmitOnError": true,
        "sourceMap": false,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,
        "lib": ["ES2020", "DOM"]
    },
    "include": ["src/**/*.ts"]
}
